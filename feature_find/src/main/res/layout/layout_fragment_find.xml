<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.su.feature.find.ui.find.FindViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FBFBFB">

        <EditText
            android:id="@+id/et_input"
            android:layout_width="300dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_edit_text"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:hint="搜索视频，作者，用户及标签"
            android:paddingStart="16dp"
            android:textColor="#ff000000"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="14dp"
            android:src="@mipmap/icon_notify"
            app:layout_constraintBottom_toBottomOf="@+id/et_input"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/et_input" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/et_input">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="分类"
                    android:textColor="#ff000000"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rcv_category"
                    android:layout_width="match_parent"
                    android:layout_height="236dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_category" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rcv_category">

                    <TextView
                        android:id="@+id/tv_anchor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="18dp"
                        android:text="主题播单"
                        android:textColor="#ff000000"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="14dp"
                        android:src="@mipmap/icon_arrow"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_anchor"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_anchor" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rcv_anchor"
                        android:layout_width="match_parent"
                        android:layout_height="178dp"
                        android:layout_marginTop="16dp"
                        android:clipToPadding="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_anchor" />

                    <TextView
                        android:id="@+id/tv_topic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="22dp"
                        android:onClick="@{()->viewModel.startTopicActivity()}"
                        android:text="话题广场"
                        android:textColor="#ff000000"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/rcv_anchor" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="14dp"
                        android:onClick="@{()->viewModel.startTopicActivity()}"
                        android:src="@mipmap/icon_arrow"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_topic"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_topic" />

                    <ImageView
                        android:id="@+id/iv_topic3"
                        imageUrl="@{viewModel.topic.get(2).image}"
                        android:layout_width="267.3dp"
                        android:layout_height="141.7dp"
                        android:layout_marginEnd="14dp"
                        android:onClick="@{()->viewModel.startTopicActivity()}"
                        android:scaleType="centerCrop"
                        android:src="#ff1493"
                        app:layout_constraintBottom_toBottomOf="@+id/iv_topic1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/iv_topic1" />

                    <ImageView
                        android:id="@+id/iv_topic2"
                        imageUrl="@{viewModel.topic.get(1).image}"
                        android:layout_width="297dp"
                        android:layout_height="157.5dp"
                        android:layout_marginEnd="22dp"
                        android:onClick="@{()->viewModel.startTopicActivity()}"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="@id/iv_topic1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/iv_topic1"
                        tools:src="#1082ff" />

                    <ImageView
                        android:id="@+id/iv_topic1"
                        imageUrl="@{viewModel.topic.get(3).image}"
                        android:layout_width="330dp"
                        android:layout_height="175dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="20dp"
                        android:onClick="@{()->viewModel.startTopicActivity()}"
                        android:scaleType="centerCrop"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_topic"
                        tools:src="@mipmap/image_topic" />

                    <TextView
                        android:id="@+id/tv_image_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="12dp"
                        android:text="@{viewModel.topic.get(3).title}"
                        android:textColor="#ffffffff"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/iv_topic1"
                        app:layout_constraintTop_toTopOf="@id/iv_topic1"
                        tools:text="冬日旅行收藏夹" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>