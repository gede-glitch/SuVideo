<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="video"
            type="com.su.data.video.bean.ResVideo" />

        <variable
            name="white"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="11dp">

        <ImageView
            android:id="@+id/iv_video"
            imageUrl="@{video.image}"
            android:layout_width="match_parent"
            android:layout_height="216dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@mipmap/bg_home_video_image" />

        <ImageView
            android:id="@+id/iv_mute"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="16dp"
            android:src="@mipmap/icon_mute"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_play"
            android:layout_width="16.5dp"
            android:layout_height="19.5dp"
            android:src="@mipmap/icon_play"
            app:layout_constraintBottom_toBottomOf="@+id/iv_video"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_video" />

        <ImageView
            android:id="@+id/iv_avatar"
            imageAvatar="@{video.avatar}"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/tv_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_title"
            tools:src="@mipmap/icon_avatar" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="20dp"
            android:text="@{video.title}"
            android:textColor="@{white ? @color/white : @color/black}"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar"
            app:layout_constraintTop_toBottomOf="@+id/iv_video"
            tools:text="孤独与自由，在世界尽头思考人生" />

        <TextView
            android:id="@+id/tv_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="15dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{video.description}"
            android:textColor="@{white ? @color/white : @color/black}"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@+id/iv_miniplay"
            app:layout_constraintStart_toStartOf="@+id/tv_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"
            tools:text="全球旅行视频精选 #旅行" />

        <ImageView
            android:id="@+id/iv_miniplay"
            android:layout_width="5dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@mipmap/icon_miniplay"
            app:layout_constraintBottom_toBottomOf="@+id/tv_label"
            app:layout_constraintEnd_toStartOf="@+id/tv_playtime"
            app:layout_constraintTop_toTopOf="@+id/tv_label" />

        <TextView
            android:id="@+id/tv_playtime"
            android:layout_width="28dp"
            android:layout_height="15dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="14dp"
            android:text="@{video.duration}"
            android:textColor="@{white ? @color/white : @color/ff444444}"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_miniplay"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_miniplay"
            tools:text="12:49" />

        <View
            android:id="@+id/v_guideline"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="21dp"
            android:layout_marginEnd="10dp"
            android:background="#33000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_label" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>